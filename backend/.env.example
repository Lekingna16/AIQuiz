# ============================================
# AIQuiz Backend - Environment Variables
# Copy file này thành .env và điền giá trị thực
# ============================================

# --- Application ---
APP_NAME=AIQuiz
APP_VERSION=1.0.0
DEBUG=true

# --- MongoDB ---
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=aiquiz

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- File Upload ---
MAX_FILE_SIZE_MB=10

# --- CORS ---
FRONTEND_URL=http://localhost:5173
